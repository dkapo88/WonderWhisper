<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Drop shadow layer (offset to bottom-right) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_shadow"/>
            <corners android:radius="@dimen/nb_radius_2"/>
        </shape>
    </item>
    <!-- Foreground card with offset -->
    <item android:left="0dp" android:top="0dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_surface"/>
            <stroke android:width="@dimen/nb_border_4" android:color="@color/nb_border"/>
            <corners android:radius="@dimen/nb_radius_2"/>
            <padding android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp"/>
        </shape>
    </item>
</layer-list>

