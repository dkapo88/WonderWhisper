<?xml version="1.0" encoding="utf-8"?>
<!--
    Special Characters button icon.
    Shows a period (large, bottom center) with three smaller dots above,
    indicating "tap for period, hold for more characters".
    24dp x 24dp viewport, white fill for tinting.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Large period at bottom center (default tap action) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,18 m-2.5,0 a2.5,2.5 0,1 1,5 0 a2.5,2.5 0,1 1,-5 0" />

    <!-- Three smaller dots above (indicates slide-to-reveal) -->
    <!-- Left dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M6,10 m-1.5,0 a1.5,1.5 0,1 1,3 0 a1.5,1.5 0,1 1,-3 0" />

    <!-- Center dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,10 m-1.5,0 a1.5,1.5 0,1 1,3 0 a1.5,1.5 0,1 1,-3 0" />

    <!-- Right dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M18,10 m-1.5,0 a1.5,1.5 0,1 1,3 0 a1.5,1.5 0,1 1,-3 0" />
</vector>
