<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow for bold neo‑brutalist offset -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_shadow"/>
            <corners android:radius="@dimen/nb_radius_2"/>
        </shape>
    </item>

    <!-- Card face -->
    <item android:right="4dp" android:bottom="4dp">
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="@color/nb_pressed"/>
                    <stroke android:width="@dimen/nb_border_4" android:color="@color/nb_border_strong"/>
                    <corners android:radius="@dimen/nb_radius_2"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/nb_surface"/>
                    <stroke android:width="@dimen/nb_border_4" android:color="@color/nb_border"/>
                    <corners android:radius="@dimen/nb_radius_2"/>
                </shape>
            </item>
        </selector>
    </item>
</layer-list>