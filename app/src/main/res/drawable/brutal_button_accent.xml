<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_shadow"/>
            <corners android:radius="@dimen/nb_radius_1"/>
        </shape>
    </item>
    <!-- Button face (accent) -->
    <item android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_pink"/>
            <stroke android:width="@dimen/nb_border_3" android:color="@color/nb_border_strong"/>
            <corners android:radius="@dimen/nb_radius_1"/>
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp"/>
        </shape>
    </item>
</layer-list>

