<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_pressed"/>
            <stroke android:width="@dimen/nb_border_4" android:color="@color/nb_border_strong"/>
            <corners android:radius="@dimen/nb_radius_2"/>
            <padding android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/nb_surface"/>
            <stroke android:width="@dimen/nb_border_4" android:color="@color/nb_border"/>
            <corners android:radius="@dimen/nb_radius_2"/>
            <padding android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp"/>
        </shape>
    </item>
</selector>

